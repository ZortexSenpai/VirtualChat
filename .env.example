# KLIPY API key for GIF picker
# Get a free key at: https://klipy.com/developers
VITE_KLIPY_API_KEY=

# Optional: preset the homeserver on the login form (e.g. https://matrix.org)
VITE_DEFAULT_HOMESERVER=

# Optional: when set to "true"/"1"/"yes", hides the homeserver field so users
# can only log in against VITE_DEFAULT_HOMESERVER.
VITE_LOCK_HOMESERVER=
